# ============================================================
#  SUPERGEN CONFIGURATION
#  Copy this file to .env and adjust values for your PC
#  Command: copy .env.example .env
# ============================================================

# Ollama LLM (sesuaikan model dengan yang terinstall di PC ini)
# Cek model tersedia: ollama list
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ChromaDB (Vector Database - lokal)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./chroma_v4
CHROMA_HR_COLLECTION=resumes
CHROMA_TRAVEL_COLLECTION=travel-docs
EMBED_MODEL=all-MiniLM-L6-v2

# Neo4j (Knowledge Graph - via Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
